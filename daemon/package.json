{
	"name": "gsap-daemon",
	"version": "0.1.0",
	"type": "module",
	"bin": {
		"gsap-daemon": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js",
		"lint": "biome check --write",
		"typecheck": "tsc --noEmit",
		"cargo:clippy": "cargo clippy --manifest-path ../cli/Cargo.toml --all-targets --all-features",
		"cargo:fmt": "cargo fmt --manifest-path ../cli/Cargo.toml",
		"cargo": "pnpm run cargo:clippy && pnpm run cargo:fmt",
		"check": "pnpm run lint && pnpm run typecheck && pnpm run cargo"
	},
	"dependencies": {
		"fastify": "^5.8.4",
		"gsap": "^3.14.2",
		"terminal-kit": "^3.1.2",
		"ws": "^8.20.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"@types/ws": "^8.18.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2"
	}
}
