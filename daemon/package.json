{
	"name": "gsap-daemon",
	"version": "0.1.0",
	"type": "module",
	"bin": {
		"gsap-daemon": "./dist/index.js"
	},
	"scripts": {
		"build": "bun run build.ts",
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"lint": "biome check --write",
		"typecheck": "tsc --noEmit",
		"cargo:clippy": "cargo clippy --manifest-path ../cli/Cargo.toml --all-targets --all-features",
		"cargo:fmt": "cargo fmt --manifest-path ../cli/Cargo.toml",
		"cargo": "bun run cargo:clippy && bun run cargo:fmt",
		"check": "bun run lint && bun run typecheck && bun run cargo"
	},
	"dependencies": {
		"gsap": "^3.14.2",
		"playwright": "^1.58.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/bun": "^1.3.11",
		"typescript": "^6.0.2"
	}
}
